generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  howFound   String
  reason     String
  approved   Boolean  @default(false)
  role       String   @default("user")
  visitCount Int      @default(0)
  createdAt  DateTime @default(now())
}
